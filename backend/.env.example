# Server
PORT=5000
NODE_ENV=production

# Railway sets DATABASE_URL automatically when you add a Postgres service.
# You do NOT need to set DB_HOST, DB_PORT etc. on Railway.
# For local development only:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=issuetrack_crm
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT — set these in Railway dashboard → Variables
JWT_SECRET=replace_this_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Set this to your Netlify URL after deploying frontend
FRONTEND_URL=https://your-app.netlify.app
