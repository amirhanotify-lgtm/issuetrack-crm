# Server
PORT=5000
NODE_ENV=production

# Railway sets DATABASE_URL automatically when you add a Postgres service.
# You do NOT need to set DB_HOST, DB_PORT etc. on Railway.
# For local development only:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=issuetrack_crm
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT — set these in Railway dashboard → Variables
JWT_SECRET=mySuperSecretKey_crm_2024_xZ9pQ
JWT_EXPIRES_IN=7d

# Set this to your Netlify URL after deploying frontend
FRONTEND_URL=https://issuetrack-crm.netlify.app

# Gmail SMTP (for sending invitations)
# Use your Gmail address and App Password (not your regular password)
# How to create App Password: https://support.google.com/accounts/answer/185833
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-gmail-app-password
